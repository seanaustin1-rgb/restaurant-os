// Weekly reputation snapshots — the time series behind Aura's "trending" read.
// Google/Yelp only return the CURRENT aggregate, so a 4–8-week trend must be
// computed from points we persist over time. Single-tenant today (Aura uses one
// env-configured place per source); `source` includes a synthetic "overall" row
// (count-weighted) so the headline trend is a single series.
model ReputationSnapshot {
  id          String   @id @default(cuid())
  source      String // "google" | "yelp" | "facebook" | "overall"
  rating      Float?
  reviewCount Int
  capturedAt  DateTime @default(now())

  @@index([source, capturedAt])
}

// Daily Google Business Profile performance metrics behind Aura's intent read.
// Values are imported by day so the dashboard can compare recent customer intent
// without calling Google on every page load.
model AuraIntentSnapshot {
  id         String   @id @default(cuid())
  source     String   @default("google_business_profile")
  metric     String
  date       DateTime @db.Date
  value      Int
  capturedAt DateTime @default(now())

  @@unique([source, metric, date])
  @@index([source, metric, date])
}

// MetricNote — a dated operator note that explains a red / over-target metric so an
// investor sees the "why" without a phone call (a scary alert becomes a "managed
// event"). `audience` is the leak guard: INTERNAL notes ("laid off 3 staff", "missed a
// debt payment") are operator-only; only INVESTOR notes surface in the investor view.
// Enforced server-side on every read AND write (src/lib/dashboard/metric-notes.ts) —
// hidden buttons are not access control. Default INTERNAL; sharing is an explicit opt-in.
model MetricNote {
  id           String       @id @default(cuid())
  restaurantId String
  metricKey    String // namespaced: "gauge-opex" | "bucket-tax-reserve" | "ratio-liquor"
  eventDate    DateTime // the dated event the note explains
  periodKey    String // e.g. "2026-06" — which period the note applies to
  body         String // length-limited at the server action
  audience     NoteAudience @default(INTERNAL)
  authorId     String // clerkUserId of the author
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  resolvedAt   DateTime? // when the managed event is closed out

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, metricKey, eventDate]) // chronological sort per metric
}

enum NoteAudience {
  INTERNAL
  INVESTOR
}

// ─────────────────────────────────────────────────────────────
// Real-estate speed-to-lead pipeline (v1, buyer-side)
//
// A brokerage is a Restaurant row with businessType REAL_ESTATE_BROKERAGE.
// BoldTrail leads land first as RawSourceEvent (audit/idempotency), then
// normalize into Lead. The response clock is receivedAt -> firstTouchAt;
// CallEvent / MessageEvent are the touch channels (calls, SMS, email) and
// stamp firstTouchAt on the ATTEMPT (a call to voicemail still counts).
// Agents are BrokerageAgent (shared with deals/leadSpend/roster) — not a
// separate identity — so leads feed the existing performance engine.
// ─────────────────────────────────────────────────────────────

// Marketing channel a lead originated from (distinct from the delivering
// system, which is BrokerageSourceSystem). Drives lead-source ROI reporting.
enum LeadSource {
  ZILLOW
  REALTOR_COM
  IDX_WEBSITE
  FACEBOOK
  REFERRAL
  OPEN_HOUSE
  OTHER
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  ENGAGED
  CONVERTED
  LOST
}

// How far the speed-to-lead alert has climbed (leakage tracking).
enum LeadEscalation {
  PRIMARY
  BACKUP
  BROKER
}

enum TouchChannel {
  CALL
  SMS
  EMAIL
}

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELED
}

enum MessageChannel {
  SMS
  EMAIL
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

model Lead {
  id           String @id @default(cuid())
  restaurantId String

  // Provenance / idempotency
  sourceSystem BrokerageSourceSystem @default(BOLDTRAIL) // integration that delivered it
  externalId   String? // BoldTrail lead id
  origin       LeadSource? // marketing channel, for ROI
  rawEventId   String? // soft link to the RawSourceEvent that created it (audit/replay)

  // Contact
  fullName String?
  email    String?
  phone    String? // E.164 for Twilio dialing

  // The response clock
  receivedAt        DateTime // webhook/campaign lead-created time — clock STARTS
  agentId           String? // assigned BrokerageAgent
  assignedAt        DateTime?
  firstTouchAt      DateTime? // first ATTEMPTED touch (call initiated / sms|email sent) — clock STOPS
  firstTouchChannel TouchChannel?
  responseSeconds   Int? // denormalized firstTouchAt − receivedAt (fast reporting)

  // Escalation / leakage
  escalation  LeadEscalation @default(PRIMARY)
  escalatedAt DateTime?

  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  agent      BrokerageAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  calls      CallEvent[]
  messages   MessageEvent[]

  @@unique([restaurantId, sourceSystem, externalId]) // idempotent upsert; mirrors BrokerageAgentSourceIdentity
  @@index([restaurantId])
  @@index([restaurantId, receivedAt])
  @@index([restaurantId, agentId])
  @@index([restaurantId, status])
}

model CallEvent {
  id           String  @id @default(cuid())
  restaurantId String
  leadId       String?
  agentId      String? // BrokerageAgent who placed/received it

  direction CallDirection @default(OUTBOUND)

  // Twilio cell-bridge legs — NO recording in v1
  agentNumber   String // agent's dedicated Twilio number (local presence)
  leadNumber    String // E.164 dialed
  conferenceSid String? @unique // parent bridge SID
  agentCallSid  String? // leg 1 — Twilio rings the agent's cell
  leadCallSid   String? // leg 2 — bridged to the lead

  status CallStatus @default(QUEUED)

  // Metadata-only logging: duration, timestamps, connection status
  initiatedAt     DateTime // agent tapped → bridge started (the first-touch instant)
  agentAnsweredAt DateTime?
  leadConnectedAt DateTime? // both legs bridged
  endedAt         DateTime?
  durationSec     Int? // talk time from Twilio status callback
  connected       Boolean   @default(false) // did the lead leg actually connect?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lead       Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agent      BrokerageAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, agentId])
  @@index([leadId])
  @@index([restaurantId, leadId, initiatedAt]) // accelerated speed-to-lead audit queries
  @@index([agentCallSid])
  @@index([leadCallSid])
}

// SMS + email touches, and the AI draft-and-approve lifecycle in one table:
// a draft is status DRAFT + aiDrafted + approvedAt null; sending stamps sentAt
// (and Lead.firstTouchAt when it's the first touch).
model MessageEvent {
  id           String  @id @default(cuid())
  restaurantId String
  leadId       String?
  agentId      String? // BrokerageAgent who owns it

  channel   MessageChannel
  direction MessageDirection @default(OUTBOUND)

  // Draft-and-approve
  aiDrafted  Boolean   @default(false) // was the body AI-generated?
  aiModel    String? // which Claude model drafted it (usage/audit)
  approvedAt DateTime? // human approved before send; null = still a draft

  subject     String? // email only
  body        String  @db.Text
  toAddress   String? // E.164 phone or email address
  fromAddress String? // agent's connected mailbox / Twilio number

  status     MessageStatus @default(DRAFT)
  providerId String?       @unique // Twilio message SID / Gmail message id (idempotency)
  sentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lead       Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agent      BrokerageAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, agentId])
  @@index([leadId])
  @@index([restaurantId, leadId, sentAt]) // symmetric clock-audit index (mirrors CallEvent)
  @@index([status])
}
