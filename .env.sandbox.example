# =============================================================================
# SANDBOX env template — an ISOLATED copy for a consultant / external reviewer.
# Nothing here points at production. Fill the <PLACEHOLDERS>, save as `.env.local`.
#
# To just SEE THE APP OPERATE you only need the THREE "REQUIRED" blocks below
# (Supabase + Clerk + the generated key). The seed script renders a full
# dashboard without Plaid/Toast. Everything under "OPTIONAL" can stay as-is.
# =============================================================================

# --- REQUIRED 1/3: Database (your OWN free Supabase project) ------------------
# supabase.com -> New project -> Project Settings -> Database -> Connection string.
# DATABASE_URL = the POOLED (PgBouncer, port 6543) "Transaction" string + ?pgbouncer=true
# DIRECT_URL   = the DIRECT (port 5432) "Session" string (used for migrations)
DATABASE_URL=<supabase-pooled-connection-string>?pgbouncer=true
DIRECT_URL=<supabase-direct-connection-string>

# --- REQUIRED 2/3: Auth (your OWN free Clerk DEV instance) --------------------
# clerk.com -> create application -> API keys. Use the DEVELOPMENT instance keys.
# Dev instances accept test logins: email you+clerk_test@example.com, code 424242.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-pub-key>
CLERK_SECRET_KEY=sk_test_<your-clerk-secret-key>
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- REQUIRED 3/3: App encryption key (freshly generated, sandbox-only) -------
# 32 bytes hex (64 chars). Regenerate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=00abb5b8d2e9dca108b29bd8495eeac745278fba626b514343f8dad5ac60faa6

NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# OPTIONAL — leave as dummy values; the related feature just won't work locally.
# Add real sandbox keys only for the specific flow you want to exercise.
# =============================================================================

# --- Plaid SANDBOX (only to test the bank-connect flow) -----------------------
# plaid.com dashboard -> Keys -> Sandbox. Link with test creds user_good / pass_good.
PLAID_CLIENT_ID=<plaid-sandbox-client-id-or-leave-dummy>
PLAID_SECRET=<plaid-sandbox-secret-or-leave-dummy>
PLAID_ENV=sandbox

# --- Inngest (background jobs) — dummy is fine for local dev ------------------
INNGEST_EVENT_KEY=sandbox-dummy
INNGEST_SIGNING_KEY=sandbox-dummy

# --- AI bank-statement import (only to test that feature) --------------------
# Use the consultant's OWN Anthropic API key; do not reuse production's.
ANTHROPIC_API_KEY=

# --- Email (Resend) — leave blank; emails simply won't send locally ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Toast POS — not needed for the demo; seed provides sales data -----------
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_API_HOSTNAME=
TOAST_RESTAURANT_GUID=
TOAST_ANALYTICS_CLIENT_ID=
TOAST_ANALYTICS_CLIENT_SECRET=

# --- Reputation (Aura: Google / Yelp / Meta) — optional ----------------------
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=
GOOGLE_BUSINESS_PROFILE_LOCATION_ID=
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_SECRET=
GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=
YELP_API_KEY=
YELP_BUSINESS_ID=
META_GRAPH_TOKEN=
FACEBOOK_PAGE_ID=
