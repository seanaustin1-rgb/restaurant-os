  importBatch VacationRentalImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@unique([restaurantId, externalReviewId])
  @@index([restaurantId])
  @@index([propertyId])
  @@index([sourceId])
  @@index([importBatchId])
  @@index([platform])
  @@index([reviewedAt])
