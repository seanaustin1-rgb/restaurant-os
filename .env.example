# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# Database — Supabase Postgres (DIRECT_URL is for Prisma Migrate)
DATABASE_URL=
DIRECT_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Encryption (generate a 32-byte hex key; do not reuse across environments)
ENCRYPTION_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend
RESEND_API_KEY=

# Anthropic — AI extraction of scanned bank statements (optional)
ANTHROPIC_API_KEY=
# STATEMENT_EXTRACT_MODEL=claude-sonnet-4-6

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
