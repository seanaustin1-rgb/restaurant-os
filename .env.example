# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# Database — Supabase Postgres (DIRECT_URL is for Prisma Migrate)
DATABASE_URL=
DIRECT_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Encryption (generate a 32-byte hex key; do not reuse across environments)
ENCRYPTION_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Anthropic — AI extraction of scanned bank statements (optional)
ANTHROPIC_API_KEY=
# STATEMENT_EXTRACT_MODEL=claude-sonnet-4-6

# Toast (POS) — restaurant integration wave. Connector stays dark until all four
# are set. Get them from the Toast developer portal (machine client / OAuth2
# client-credentials). TOAST_API_HOSTNAME is the API base, e.g.
# https://ws-api.toasttab.com (prod) or the sandbox host you were issued.
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_API_HOSTNAME=
TOAST_RESTAURANT_GUID=
# Optional second credential set for the Analytics (era / enterprise-metrics) API.
# Toast splits Analytics vs Standard (operational) access across SEPARATE API
# clients, so the base TOAST_CLIENT_ID/SECRET above hold the operational (Standard)
# creds and these hold the Analytics creds. If left blank, analytics falls back to
# the base creds (single-credential-set setups keep working).
TOAST_ANALYTICS_CLIENT_ID=
TOAST_ANALYTICS_CLIENT_SECRET=

# Aura (Reputation) — multi-source reviews. Each source is independent: set its
# vars and that source lights up on the /modules/aura tile; leave them blank and
# it shows a "connect me" card. Nothing here is required for the app to run.
#   Google: Places API key + the restaurant's Place ID
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
#   Google Business Profile performance: calls, directions, website clicks,
#   profile views. Prefer refresh-token credentials for production; a one-off
#   access token works briefly but expires.
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=
GOOGLE_BUSINESS_PROFILE_LOCATION_ID=
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_SECRET=
GOOGLE_BUSINESS_PROFILE_REFRESH_TOKEN=
#   Yelp: Fusion API key + the business ID (slug or encoded id)
YELP_API_KEY=
YELP_BUSINESS_ID=
#   Facebook: a Page access token (with pages_read_user_content) + the Page ID
META_GRAPH_TOKEN=
FACEBOOK_PAGE_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
