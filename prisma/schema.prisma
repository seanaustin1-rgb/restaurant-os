  googleIntentTrendPct Decimal? @db.Decimal(6, 2)
  rawPayload           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, market, date])
  @@index([restaurantId])
  @@index([market])
  @@index([date])
}

model ReviewCache {
